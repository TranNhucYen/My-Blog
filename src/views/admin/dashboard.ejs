<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
        <title>Dashboard - Admin Panel</title>
</head>

<body class="bg-gray-100">
    <!-- modal overlay -->
    <div id="modal-form-admin" data-modal=""
        class="absolute flex justify-center items-center inset-0 -top-20 bg-black/50 z-50 hidden ">
        <div class="flex flex-col bg-white text-black p-6 rounded-xl w-1/3 shadow">
            <div class="text-2xl mb-4 text-center font-semibold">Thêm admin</div>
            <div class="space-y-4">
                <div class="flex flex-col space-y-1">
                    <label class="font-medium">Username</label>
                    <input name="username" type="text"
                        class="border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div class="flex flex-col space-y-1">
                    <label class="font-medium">Email</label>
                    <input name="email" type="email"
                        class="border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div class="flex gap-x-3">
                    <button data-action="create-admin"
                        class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition">
                        Thêm mới
                    </button>
                    <button onclick="this.closest('[data-modal]').classList.add('hidden')"
                        class="w-full bg-white border-2 border-blue-600 text-blue-600 py-2 rounded-lg hover:bg-gray-100 transition">
                        Hủy
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!-- Overlay for mobile -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-40 hidden md:hidden"></div>
    <div id="toast-container" class=""></div>

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <aside id="sidebar"
            class="w-64 bg-gray-800 text-white flex-shrink-0 transition-all duration-300 fixed md:fixed h-full z-50 translate-x-0">
            <div class="p-4 border-b border-gray-700">
                <h2 class="text-2xl font-bold">Admin Panel</h2>
                <p class="text-sm text-gray-400 mt-1">Welcome, <%= user.username %>
                </p>
            </div>

            <nav class="p-4">
                <ul class="space-y-2">
                    <!-- Dashboard -->
                    <li>
                        <a href="/admin/dashboard"
                            class="flex items-center p-3 rounded-lg hover:bg-gray-700 transition-colors bg-gray-700">
                            <i class="fas fa-home w-6"></i>
                            <span class="ml-3">Dashboard</span>
                        </a>
                    </li>

                    <!-- Quản lý Admin -->
                    <% if (user.role==='superadmin' ) { %>
                        <li>
                            <button
                                class="w-full flex items-center justify-between p-3 rounded-lg hover:bg-gray-700 transition-colors"
                                onclick="toggleSubmenu('admin-menu')">
                                <div class="flex items-center">
                                    <i class="fas fa-user-shield w-6"></i>
                                    <span class="ml-3">Quản lý Admin</span>
                                </div>
                                <i class="fas fa-chevron-down transition-transform" id="admin-menu-icon"></i>
                            </button>
                            <ul id="admin-menu" class="ml-6 mt-2 space-y-1 hidden">
                                <li id="btn-list-admin">
                                    <a href=""
                                        class="flex items-center p-2 rounded-lg hover:bg-gray-700 transition-colors">
                                        <i class="fas fa-list w-5 text-sm"></i>
                                        <span class="ml-2 text-sm">Danh sách Admin</span>
                                    </a>
                                </li>
                                <li id="btn-add-admin">
                                    <a class="flex items-center p-2 rounded-lg hover:bg-gray-700 transition-colors">
                                        <i class="fas fa-plus w-5 text-sm"></i>
                                        <span class="ml-2 text-sm">Thêm Admin</span>
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <% } %>

                            <!-- Quản lý Bài viết -->
                            <li>
                                <button
                                    class="w-full flex items-center justify-between p-3 rounded-lg hover:bg-gray-700 transition-colors"
                                    onclick="toggleSubmenu('posts-menu')">
                                    <div class="flex items-center">
                                        <i class="fas fa-file-alt w-6"></i>
                                        <span class="ml-3">Quản lý Bài viết</span>
                                    </div>
                                    <i class="fas fa-chevron-down transition-transform" id="posts-menu-icon"></i>
                                </button>
                                <ul id="posts-menu" class="ml-6 mt-2 space-y-1 hidden">
                                    <li id="btn-list-post">
                                        <a class="flex items-center p-2 rounded-lg hover:bg-gray-700 transition-colors">
                                            <i class="fas fa-list w-5 text-sm"></i>
                                            <span class="ml-2 text-sm">Danh sách Bài viết</span>
                                        </a>
                                    </li>
                                    <li id="btn-add-post">
                                        <a class="flex items-center p-2 rounded-lg hover:bg-gray-700 transition-colors">
                                            <i class="fas fa-plus w-5 text-sm"></i>
                                            <span class="ml-2 text-sm">Tạo Bài viết</span>
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <!-- Logout -->
                            <li id="btn-logout" class="pt-4 border-t border-gray-700">
                                <div class="flex items-center p-3 rounded-lg hover:bg-red-600 transition-colors">
                                    <i class="fas fa-sign-out-alt w-6"></i>
                                    <span class="ml-3">
                                        <a href="/auth/logout">Đăng xuất</a>
                                    </span>
                                </div>
                            </li>
                </ul>
            </nav>
        </aside>

        <!-- Main Content -->
        <div id="main-content" class="flex-1 flex flex-col overflow-hidden w-full transition-all duration-300">
            <!-- Header -->
            <header class="bg-white shadow-md p-4 flex items-center justify-between z-30">
                <div class="flex items-center space-x-4">
                    <button id="sidebar-toggle" class="text-gray-600 hover:text-gray-800 focus:outline-none">
                        <i class="fas fa-bars text-xl"></i>
                    </button>
                    <h2 class="text-lg font-semibold text-gray-800 hidden md:block">Admin Panel</h2>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="text-right hidden sm:block">
                        <p class="text-sm font-bold text-gray-700">
                            <%= user.username %>
                        </p>
                        <p class="text-xs text-gray-500">
                            <%= user.role %>
                        </p>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-gray-300 flex items-center justify-center">
                        <i class="fas fa-user text-gray-600"></i>
                    </div>
                </div>
            </header>
            <!-- Content Area -->
            <main id="content-area" class="flex-1 overflow-y-auto p-6">
                <div class="mb-6">
                    <h1 class="text-3xl font-bold text-gray-800">Dashboard</h1>
                    <p class="text-gray-600 mt-2">Chào mừng bạn đến với trang quản trị</p>
                </div>

                <!-- Stats Cards -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-500 text-sm">Tổng Admin</p>
                                <h3 class="text-2xl font-bold text-gray-800 mt-1">
                                    <%= statistics.admin.totalAdmin || "Không có dữ liệu" %>
                                </h3>
                            </div>
                            <div class="bg-blue-100 rounded-full p-3">
                                <i class="fas fa-user-shield text-blue-600 text-xl"></i>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-lg shadow-md p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-500 text-sm">Tổng Bài viết</p>
                                <h3 class="text-2xl font-bold text-gray-800 mt-1">
                                    <%= statistics.post?.totalPosts || "Không có dữ liệu" %>
                                </h3>
                            </div>
                            <div class="bg-green-100 rounded-full p-3">
                                <i class="fas fa-file-alt text-green-600 text-xl"></i>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-lg shadow-md p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-500 text-sm">Bài viết hôm nay</p>
                                <h3 class="text-2xl font-bold text-gray-800 mt-1">0</h3>
                            </div>
                            <div class="bg-yellow-100 rounded-full p-3">
                                <i class="fas fa-calendar-day text-yellow-600 text-xl"></i>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-lg shadow-md p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-500 text-sm">Lượt truy cập</p>
                                <h3 class="text-2xl font-bold text-gray-800 mt-1">1</h3>
                            </div>
                            <div class="bg-purple-100 rounded-full p-3">
                                <i class="fas fa-chart-line text-purple-600 text-xl"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts Section -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
                    <!-- Posts per Admin Chart -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <h3 class="text-xl font-bold text-gray-800 mb-4">Bài viết theo Admin</h3>
                        <div class="relative h-64">
                            <canvas id="postsPerAdminChart"></canvas>
                        </div>
                    </div>

                    <!-- Posts per Day Chart -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <h3 class="text-xl font-bold text-gray-800 mb-4">Bài viết theo ngày</h3>
                        <div class="relative h-64">
                            <canvas id="postsPerDayChart"></canvas>
                        </div>
                    </div>
                </div>


            </main>
        </div>
    </div>

    <script src="/vendor/gridjs.bundle.js"></script>
    <script src="/vendor/chartjs.bundle.js"></script>
    <script src="/js/utils/fetchAPI.js"></script>
    <script src="/js/utils/toast.js"></script>
    <script src="/js/adminSidebar.js"></script>
    <script src="/js/adminPostTable.js"></script>
    <script src="/js/adminUserTable.js"></script>
    <script src="/js/adminStatistics.js"></script>


</body>

</html>